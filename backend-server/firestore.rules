rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       HELPER FUNCTIONS
    ====================== */
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    /* ======================
       PUBLIC READ (MENU)
    ====================== */
    match /products/{id} {
      allow read: if true;          // anyone can see menu
      allow write: if isAdmin();    // only admin can change menu
    }

    match /offers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ======================
       OUTLET & TABLE SETUP
    ====================== */
    match /outlets/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /tables/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    /* ======================
       BACKEND-ONLY COLLECTIONS
       (Cloud Functions via Admin SDK)
    ====================== */
    match /orders/{id} {
      allow read, write: if false;
    }

    match /sessions/{id} {
      allow read, write: if false;
    }

    match /payments/{id} {
      allow read, write: if false;
    }

    match /customers/{id} {
      allow read, write: if false;
    }

    match /loyaltyTransactions/{id} {
      allow read, write: if false;
    }

    match /dailyReports/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
